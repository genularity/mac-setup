[credential]
	helper = /opt/homebrew/bin/op plugin run -- gh auth git-credential

[core]
	editor = nvim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = tokyonight_night

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[fetch]
	prune = true

[rerere]
	enabled = true

[alias]
	lg = log --oneline --graph --decorate --all
	st = status -sb
	co = checkout
	br = branch
	cm = commit
	last = log -1 HEAD --stat
	unstage = reset HEAD --
